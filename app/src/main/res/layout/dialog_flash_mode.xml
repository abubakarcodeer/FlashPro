<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background"
    android:orientation="vertical"
    >

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="25dp"
        android:text="@string/choosing_flasing_type"
        android:textSize="22sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="?attr/dialogViewColor" />

    <RadioGroup
        android:id="@+id/radioGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginVertical="20dp">


        <RadioButton
            android:id="@+id/normal_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/normal"
            android:textSize="20sp"
            android:button="@null"
            android:drawableStart="@drawable/radio_selector"
            android:drawablePadding="15dp"
            android:paddingEnd="20dp"
            android:checked="true"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/rhythm_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rhythm"
            android:button="@null"
            android:drawableStart="@drawable/radio_selector"
            android:drawablePadding="15dp"
            android:paddingEnd="20dp"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RadioGroup>


</LinearLayout>